{
  "name": "@akyma/bk-ui",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "watch:build": "chokidar \"src/**/*\" \"package.json\" \"vite.config.js\" --ignore \"dist/**\" --debounce 3000 -c \"npm run build\"",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "quasar": "^2.0.0",
    "vue": "^3.4.0",
    "vue-meteor-tracker": "^3.0.0-beta.7"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "chokidar-cli": "^3.0.0",
    "quasar": "^2.18.6",
    "vite": "^5.4.0",
    "vue": "^3.4.18",
    "vue-meteor-tracker": "^3.0.0-beta.7"
  }
}
